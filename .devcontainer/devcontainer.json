{
    // For format details, see https://aka.ms/devcontainer.json.
    "name": "Debian",
    // https://github.com/devcontainers/images/tree/main/src/base-debian
    // The :debian tag is the latest Debian stable release
    // Other base images: https://github.com/devcontainers/images
    "image": "mcr.microsoft.com/devcontainers/base:debian@sha256:aa263c6fdd7c1bc990eead3922224fe8afbf5d85eaf3b6b9260786ab94d74933",
    // Available features: https://containers.dev/features
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "moby": false,
        },
        "ghcr.io/devcontainers/features/github-cli:1.1.0": {},
        "ghcr.io/devcontainers/features/go:1.3.3":{},
        "ghcr.io/devcontainers/features/node:1.7.1": {
            "version": "lts",
            "installYarnUsingApt": "false"
        },
        "ghcr.io/devcontainers-extra/features/opencode:1.0.0": {},
        "ghcr.io/devcontainers-extra/features/pre-commit:2.0.18": {},
        "ghcr.io/devcontainers-extra/features/shellcheck:1.1.0": {},
        "ghcr.io/devcontainers-extra/features/uv:1.0.2": {},
        "ghcr.io/dhoeric/features/hadolint:1.0.0": {},
    },
    "containerEnv": {
        // "UV_CACHE_DIR": "${containerWorkspaceFolder}/.uv_cache",
        // https://github.com/microsoft/playwright-cli#environment
        "PLAYWRIGHT_MCP_CAPS": "vision",
        "PLAYWRIGHT_MCP_HEADLESS": "true",
    },
    "postCreateCommand": {
        // Install pre-commit hooks in the background since they can take a
        // while, and we want to minimize waiting during `git commit`
        "Initialize pre-commit environment": "nohup sh -c 'pre-commit install -f --install-hooks &' < /dev/null > /dev/null 2>&1",
        "Install packages": ".devcontainer/install-packages.sh",
    },
    "mounts": [
        {
            // Mount Google cloud credentials
            "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.config/gcloud/application_default_credentials.json",
            "target": "/home/vscode/.config/gcloud/application_default_credentials.json",
            "type": "bind",
        },
        {
            // Mount user's claude config dir
            "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.claude",
            "target": "/home/vscode/.claude",
            "type": "bind",
        },
        {
            // Mount user's claude config file
            "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.claude.json",
            "target": "/home/vscode/.claude.json",
            "type": "bind",
        },
    ],
    "remoteEnv": {
        // Pass through variables to enable Claude Code
        "ANTHROPIC_VERTEX_PROJECT_ID": "${localEnv:ANTHROPIC_VERTEX_PROJECT_ID}",
        "CLAUDE_CODE_USE_VERTEX": "1",
        "CLOUD_ML_REGION": "${localEnv:CLOUD_ML_REGION}",
        "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}",
        // Pass through Context7 API key for MCP access
        "CONTEXT7_API_KEY": "${localEnv:CONTEXT7_API_KEY}",
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "sst-dev.opencode"
            ]
        }
    },
}
